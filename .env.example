# Pi-hole web admin password
PIHOLE_PASSWORD=changeme

# Docker network IPs (dns_net bridge)
DNS_NET_SUBNET=172.18.0.0/16
UNBOUND_BRIDGE_IP=172.18.0.8#5353
PIHOLE_BRIDGE_IP=172.18.0.9

# Pi-hole IP on your LAN (host network)
PIHOLE_BASE_IP=192.168.0.9

# Local domain for internal hostnames
LOCAL_DOMAIN=maliam.net

# Pi-hole admin panel port (default: 8080)
PIHOLE_HTTP_PORT=8080

# Optional: override Unbound data path (default: ./unbound)
UNBOUND_DATA_PATH=/opt/stacks/unhole/unbound
