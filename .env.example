# Pi-hole web admin password
PIHOLE_PASSWORD=changeme

# Docker network IPs (dns_net bridge)
DNS_NET_SUBNET=172.18.0.0/16
UNBOUND_BRIDGE_IP=172.18.0.8
PIHOLE_BRIDGE_IP=172.18.0.9

# Pi-hole IP on your LAN (host network)
PIHOLE_BASE_IP=192.168.0.9

# Local domain for internal hostnames
LOCAL_DOMAIN=maliam.net

# Pi-hole admin panel port (default: 8080)
PIHOLE_HTTP_PORT=8080

# Optional: override Unbound data path (default: ./unbound)
UNBOUND_DATA_PATH=/opt/stacks/unhole/unbound

# Pi-hole custom DNS hosts (A records): "IP hostname" per line. If multiline fails, use \n between entries.
FTLCONF_dns_hosts="192.168.0.9 jazz.maliam.net
192.168.0.10 wheeljack.maliam.net
192.168.0.11 nacelle.maliam.net
192.168.0.12 camshaft.maliam.net
192.168.0.13 photon.maliam.net
192.168.0.14 ironhide.maliam.net
192.168.0.15 bumblebee.maliam.net
192.168.0.16 grimlock.maliam.net
192.168.0.17 unicron.maliam.net"

# Pi-hole custom CNAME records: "alias,target" per line.
FTLCONF_dns_cnameRecords="dns.maliam.net,jazz.maliam.net
nas.maliam.net,wheeljack.maliam.net
traefik-dashboard.maliam.net,jazz.maliam.net
home.maliam.net,jazz.maliam.net
pihole.maliam.net,jazz.maliam.net
media.maliam.net,jazz.maliam.net
homeassistant.maliam.net,bumblebee.maliam.net
ha.maliam.net,jazz.maliam.net"
